{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "outDir": "dist",
        "rootDir": "_src",
        "resolveJsonModule": true,
        "declaration": true,
        "skipLibCheck": true
    },
    "include": [
        "_src/**/*"
    ]
}