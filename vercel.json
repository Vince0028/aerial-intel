{
    "version": 2,
    "buildCommand": "cd api && npm ci && cd ../frontend && npm ci && npm run build",
    "outputDirectory": "frontend/dist",
    "installCommand": "echo 'installing via buildCommand'",
    "functions": {
        "api/index.ts": {
            "maxDuration": 30,
            "memory": 512
        }
    },
    "crons": [
        {
            "path": "/api/cleanup",
            "schedule": "0 2 * * *"
        }
    ],
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api/index.ts" },
        { "source": "/((?!api/).*)", "destination": "/index.html" }
    ]
}
